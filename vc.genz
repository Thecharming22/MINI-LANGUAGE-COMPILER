dm text = "aeioubcd";
sigma vowels = 0;
sigma conso =0;

spam(sigma i = 0; i < text.length; i++)
{
    vibeCheck(
        text[i]=="a"||text[i]=="e"||text[i]=="i"||
        text[i]=="o"||text[i]=="u"||
        text[i]=="A"||text[i]=="E"||text[i]=="I"||
        text[i]=="O"||text[i]=="U"
    ){
